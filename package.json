{
  "name": "hotel-robot",
  "version": "0.1.0",
  "description": "Hotel Receptionist Voice Agent — host-agnostic orchestration platform",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server/index.js",
    "dev": "ts-node-dev --respawn --transpile-only --project tsconfig.json src/server/index.ts",
    "ingest": "ts-node --project tsconfig.json src/core/rag/ingest.ts",
    "test": "ts-node --project tsconfig.test.json tests/policy.test.ts",
    "test:verifier": "ts-node --project tsconfig.test.json tests/verifier.test.ts",
    "test:all": "npm test && npm run test:verifier",
    "test:scenarios": "ts-node --project tsconfig.test.json tests/scenarios.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "mrz": "^5.0.1",
    "openai": "^4.47.1",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/uuid": "^9.0.8",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
